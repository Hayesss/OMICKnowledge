{
  "nodes": [
    {
      "id": "annotation",
      "name": "注释与解读",
      "type": "stage",
      "description": "对鉴定出的 peaks 进行基因组注释，关联到附近的基因和调控元件。",
      "difficulty": "intermediate",
      "tags": [
        "atac-seq",
        "annotation",
        "functional-analysis"
      ],
      "source": "manual",
      "last_updated": "2026-04-01"
    },
    {
      "id": "peak-calling",
      "name": "Peak Calling",
      "type": "stage",
      "description": "从比对结果中识别染色质开放区域（peaks），是 ATAC-seq 分析的核心步骤。",
      "difficulty": "intermediate",
      "tags": [
        "atac-seq",
        "peak-calling",
        "regulatory-elements"
      ],
      "source": "manual",
      "last_updated": "2026-04-01"
    },
    {
      "id": "preprocessing",
      "name": "数据预处理",
      "type": "stage",
      "description": "对原始测序数据进行质量控制、比对和过滤，为后续分析准备干净的 BAM 文件。",
      "difficulty": "beginner",
      "tags": [
        "atac-seq",
        "preprocessing",
        "qc"
      ],
      "source": "manual",
      "last_updated": "2026-04-01"
    },
    {
      "id": "alignment",
      "name": "序列比对",
      "type": "step",
      "description": "将过滤后的 reads 比对到参考基因组，生成 BAM 文件。",
      "difficulty": "beginner",
      "tags": [
        "atac-seq",
        "alignment",
        "preprocessing"
      ],
      "source": "manual",
      "last_updated": "2026-04-01",
      "input": "过滤后的 FASTQ 文件",
      "output": "BAM 文件",
      "key_params": [
        {
          "name": "max_insert_size",
          "description": "最大插入片段大小",
          "default": "1000"
        }
      ]
    },
    {
      "id": "quality-control",
      "name": "质量控制",
      "type": "step",
      "description": "评估原始测序数据质量，检查接头污染、测序深度、重复率等指标。",
      "difficulty": "beginner",
      "tags": [
        "atac-seq",
        "qc",
        "preprocessing"
      ],
      "source": "manual",
      "last_updated": "2026-04-01",
      "input": "原始 FASTQ 文件",
      "output": "质控报告（HTML/TXT）",
      "key_params": [
        {
          "name": "adapter_sequence",
          "description": "接头序列，用于去除接头污染",
          "default": "auto-detect"
        }
      ]
    },
    {
      "id": "peak-annotation",
      "name": "Peak 注释",
      "type": "step",
      "description": "将 peaks 注释到最近的基因和调控元件，分析其功能富集。",
      "difficulty": "intermediate",
      "tags": [
        "atac-seq",
        "annotation"
      ],
      "source": "manual",
      "last_updated": "2026-04-01",
      "input": "Peak 文件（BED）",
      "output": "注释结果表",
      "key_params": [
        {
          "name": "tss_distance",
          "description": "距离 TSS 的最大范围",
          "default": "3000"
        }
      ]
    },
    {
      "id": "peak-calling-step",
      "name": "Peak 识别",
      "type": "step",
      "description": "使用 peak caller 从 BAM 文件中识别染色质开放区域。",
      "difficulty": "intermediate",
      "tags": [
        "atac-seq",
        "peak-calling"
      ],
      "source": "manual",
      "last_updated": "2026-04-01",
      "input": "过滤后的 BAM 文件",
      "output": "Peak 文件（BED/NarrowPeak）",
      "key_params": [
        {
          "name": "qvalue",
          "description": "q-value 阈值",
          "default": "0.05"
        },
        {
          "name": "nomodel",
          "description": "是否跳过模型构建",
          "default": "false"
        }
      ]
    },
    {
      "id": "batch-effect",
      "name": "批次效应",
      "type": "issue",
      "description": "由于实验时间、操作人员、试剂批次等非生物学因素导致的数据系统性差异。",
      "difficulty": "intermediate",
      "tags": [
        "atac-seq",
        "scRNA-seq",
        "qc",
        "multi-sample"
      ],
      "source": "manual",
      "last_updated": "2026-04-01",
      "solution": "1. 实验设计阶段尽量平衡批次因素\n2. 分析阶段使用批次校正工具（如 ComBat, Harmony, MNN）\n3. 在质控和可视化中检查批次效应是否被有效去除\n",
      "related_tools": [
        "harmony",
        "combat"
      ]
    },
    {
      "id": "bowtie2",
      "name": "Bowtie2",
      "type": "tool",
      "description": "快速且内存高效的短序列比对工具，广泛用于 ATAC-seq 和 ChIP-seq 数据的比对。",
      "difficulty": "beginner",
      "tags": [
        "atac-seq",
        "alignment",
        "cut-tag"
      ],
      "source": "manual",
      "last_updated": "2026-04-01",
      "version": "2.5.1",
      "install_cmd": "conda install -c bioconda bowtie2",
      "doc_url": "https://bowtie-bio.sourceforge.net/bowtie2/manual.shtml",
      "pros": [
        "比对速度快",
        "支持局部比对和嵌合比对",
        "内存占用相对较低"
      ],
      "cons": [
        "对长 reads 支持不如 BWA-MEM"
      ],
      "key_params": [
        {
          "name": "-X",
          "description": "最大插入片段大小",
          "default": "1000"
        },
        {
          "name": "--very-sensitive",
          "description": "使用高灵敏度预设参数",
          "default": "false"
        }
      ]
    },
    {
      "id": "macs2",
      "name": "MACS2",
      "type": "tool",
      "description": "最常用的 ChIP-seq 和 ATAC-seq peak calling 工具，支持 narrow、broad 和 gapped peak 模型。",
      "difficulty": "beginner",
      "tags": [
        "atac-seq",
        "cut-tag",
        "peak-calling"
      ],
      "source": "manual",
      "last_updated": "2026-04-01",
      "version": "2.2.9.1",
      "install_cmd": "pip install MACS2",
      "doc_url": "https://github.com/macs3-project/MACS",
      "pros": [
        "社区广泛使用，文档丰富",
        "支持多种 peak 模型",
        "可生成 bedGraph 用于可视化"
      ],
      "cons": [
        "对 CUT&Tag 数据可能需要调整参数",
        "大样本运行时内存占用较高"
      ],
      "key_params": [
        {
          "name": "-q",
          "description": "q-value 阈值",
          "default": "0.05"
        },
        {
          "name": "--nomodel",
          "description": "跳过模型构建，适用于 ATAC-seq",
          "default": "false"
        },
        {
          "name": "--shift",
          "description": "reads 偏移量",
          "default": "-75"
        },
        {
          "name": "--extsize",
          "description": "扩展片段大小",
          "default": "150"
        }
      ]
    },
    {
      "id": "macs2-doc",
      "name": "MACS2 官方文档",
      "type": "resource",
      "description": "MACS2 GitHub 仓库和用户使用手册",
      "difficulty": "beginner",
      "tags": [
        "macs2",
        "peak-calling",
        "documentation"
      ],
      "source": "manual",
      "last_updated": "2026-04-01",
      "url": "https://github.com/macs3-project/MACS",
      "resource_type": "documentation"
    },
    {
      "id": "fdr",
      "name": "False Discovery Rate (FDR)",
      "type": "concept",
      "description": "错误发现率，即在所有被判定为显著的检验中，错误拒绝原假设的预期比例。",
      "difficulty": "intermediate",
      "tags": [
        "statistics",
        "peak-calling",
        "differential-analysis"
      ],
      "source": "manual",
      "last_updated": "2026-04-01",
      "detailed_explanation": "FDR = E[V/R | R > 0] * P(R > 0)，其中 V 是假阳性数，R 是总拒绝数。\n在 peak calling 中，常用 q-value 控制 FDR。与 p-value 相比，FDR 更适合大规模多重检验场景。\n",
      "common_misconceptions": [
        "q-value 和 p-value 是一样的（错误，q-value 考虑了多重检验校正）"
      ]
    },
    {
      "id": "fragment-size",
      "name": "Fragment Size",
      "type": "concept",
      "description": "ATAC-seq 中 DNA 片段的大小分布，反映了核小体占位和开放染色质特征。",
      "difficulty": "beginner",
      "tags": [
        "atac-seq",
        "qc",
        "nucleosome"
      ],
      "source": "manual",
      "last_updated": "2026-04-01",
      "detailed_explanation": "ATAC-seq 的 fragment size 分布通常呈现周期性峰：\n- ~50 bp：无核小体区域（NFR），代表开放染色质\n- ~200 bp：单核小体区域\n- ~400 bp：双核小体区域\n通过分析 fragment size 分布可以评估 ATAC-seq 数据质量。\n",
      "common_misconceptions": [
        "fragment size 越大越好（错误，不同大小反映不同生物学状态）"
      ]
    },
    {
      "id": "atac-seq",
      "name": "ATAC-seq",
      "type": "assay",
      "description": "利用转座酶可及性分析染色质开放区域的高通量测序技术，用于鉴定调控元件和潜在增强子。",
      "difficulty": "intermediate",
      "tags": [
        "atac-seq",
        "epigenomics",
        "chromatin-accessibility"
      ],
      "source": "manual",
      "last_updated": "2026-04-01"
    }
